# --- Database ---
# Neon Postgres connection string. Get from https://console.neon.tech
# Use the pooled ("-pooler") connection for serverless.
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/neondb?sslmode=require"

# --- Steam Web API ---
# Get a free key from https://steamcommunity.com/dev/apikey
STEAM_API_KEY=""

# --- Cron protection ---
# Random string. Vercel Cron must send it as the `x-cron-secret` header.
CRON_SECRET=""

# --- Admin (Phase 4) ---
ADMIN_PASSWORD=""
# At least 32 characters of random bytes for iron-session.
SESSION_SECRET=""

# --- Public site URL (for sitemap + robots) ---
NEXT_PUBLIC_SITE_URL="https://your-domain.vercel.app"

# --- Captcha images (private storage) ---
# The 25 captcha jpgs live in a private GitHub repo and are fetched at
# build time by scripts/fetch-captcha-images.ts. Keeps them out of this
# public repo so a cloner can't build a perceptual-hash cheat table.
# Token: fine-grained PAT with "Contents: Read" on the private repo only.
CAPTCHA_IMAGES_TOKEN=""
CAPTCHA_IMAGES_REPO="owner/sm-captcha-images"
# Optional overrides:
# CAPTCHA_IMAGES_BRANCH="main"
# CAPTCHA_IMAGES_PATH=""
