# Captcha images live in a private GitHub repo and are fetched at build
# time by scripts/fetch-captcha-images.ts. Keeping them out of the public
# repo prevents a cloner from building a perceptual-hash cheat table.
# The generated json manifest embeds the same binaries and is likewise kept
# out of the public repo.
/lib/captcha/images/*.jpg
/lib/captcha/_images.generated.json

# Blockdle block database + icons live in a separate private GitHub repo
# and are fetched at build time by scripts/fetch-blockdle-data.ts. Game
# assets (icons) are Scrap Mechanic IP; keeping them out of the public repo
# matches the captcha pattern and avoids redistributing game content.
/lib/blockdle/blocks.json
/lib/blockdle/blocks.generated.ts
/lib/blockdle/autocomplete.generated.ts
/lib/blockdle/_icons.generated.json
/lib/blockdle/icons/
/blockdle-data-tmp/
/tmp-blockdle/

# Local Claude Code harness state — per-machine lock files and isolated
# worktrees shouldn't pollute git status or linting.
.claude/scheduled_tasks.lock
.claude/worktrees/

# Built extension package — regenerated on demand from the extension/
# source folder. Distributed via GitHub Releases / AMO / Chrome Web Store
# rather than committed to history.
/smse-extension.zip
