{
  "manifest_version": 3,
  "name": "Scrap Mechanic Search Engine",
  "short_name": "SMSE",
  "version": "0.1.2",
  "description": "Shows a badge on Scrap Mechanic Workshop item pages: ✓ on Scrap Mechanic Search Engine, or one-click submit if it isn't.",
  "homepage_url": "https://scrap-mechanic-search-engine.vercel.app",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "smse@scrap-mechanic-search-engine.vercel.app",
      "strict_min_version": "115.0"
    }
  },
  "host_permissions": [
    "https://scrap-mechanic-search-engine.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "https://steamcommunity.com/sharedfiles/filedetails/*",
        "https://steamcommunity.com/workshop/filedetails/*"
      ],
      "js": ["content.js"],
      "css": ["badge.css"],
      "run_at": "document_idle"
    }
  ]
}
