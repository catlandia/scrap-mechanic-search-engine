{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_USE_POWERSHELL_TOOL": "1"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "mcp__*",
      "Bash(npm --version)",
      "Bash(git --version)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(npm run *)",
      "Bash(git commit *)",
      "Bash(rm -rf \"app/api/captcha/debug\")",
      "Bash(git pull *)",
      "Bash(mv lib/blockdle/blocks.json.bak lib/blockdle/blocks.json)",
      "Bash(mv lib/blockdle/icons.bak lib/blockdle/icons)",
      "Bash(npx tsx *)"
    ],
    "deny": [
      "Bash(format *)",
      "Bash(diskpart*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(del /s /q C:\\*)",
      "Bash(rd /s /q C:\\*)",
      "Bash(dd if=* of=/dev/sd*)",
      "Bash(mkfs*)",
      "Bash(shred /dev/*)",
      "Bash(cipher /w:C*)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(gh pr create*)",
      "Bash(gh release create*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "enableAllProjectMcpServers": true,
  "disabledMcpjsonServers": [],
  "enabledPlugins": {
    "vercel@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true
}
